#!run
// -n=name -i=icon cmd args...
export async function main(...args){
  const pf=this.resolve("/package.json");
  const p=pf.obj();
  const a= this.collectOptions(args);
  const opt=a.pop();
  if(a.length==0){
    a.push("edit",this.cwd());
  }
  const n=(p)=>{
    if(!p)return null;
    const a=(p+"").
      replace(/\/$/,"").
      split("/");
    return a.pop();
  };
  const name=opt.name||
    n(a[1])||n(a[0])||this.cwd().name();
  const icon=opt.icon||
    name[0];
  p.menus=p.menus||{};
  p.menus[name]={
    "icontext":icon,
    "main": process.env.boot,
    "call": [
      "main",{
        "cmd":a.join(" ")
      }
    ]
  };
  pf.obj(p);
  return ;
}