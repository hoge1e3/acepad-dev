#!run
import * as menu from "@acepad/menu";
import * as assert from "assert";
export async function main(f){
  const m=menu.Menu(
    this.$acepad.getMainEditor());
  const m1=m.add("value",()=>{
     //m1.text();
    
  });
  if(typeof f!=="function"){
    f.on("change",({val})=>{
      m1.text(val);
    });
    m1.text(f.value);
    
  }else{
    setInterval(()=>
    m1.text(f()),16);
  }
}    
